{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"slug": "ink",
					"color": "#171717",
					"name": "Ink"
				},
				{
					"slug": "paper",
					"color": "#FAF9F6",
					"name": "Paper"
				},
				{
					"slug": "mist",
					"color": "#E8ECE7",
					"name": "Mist"
				},
				{
					"slug": "clay",
					"color": "#B86F52",
					"name": "Clay"
				},
				{
					"slug": "evergreen",
					"color": "#21483E",
					"name": "Evergreen"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "2"
				},
				{
					"slug": "30",
					"size": "1rem",
					"name": "3"
				},
				{
					"slug": "40",
					"size": "1.5rem",
					"name": "4"
				},
				{
					"slug": "50",
					"size": "2.5rem",
					"name": "5"
				},
				{
					"slug": "60",
					"size": "4rem",
					"name": "6"
				},
				{
					"slug": "70",
					"size": "6rem",
					"name": "7"
				}
			],
			"units": [
				"px",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "system-sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"name": "System Sans"
				},
				{
					"slug": "serif-display",
					"fontFamily": "Georgia, \"Times New Roman\", serif",
					"name": "Serif Display"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.35rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "clamp(2.2rem, 6vw, 5rem)",
					"name": "Extra Large"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|paper",
			"text": "var:preset|color|ink"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "6px"
				},
				"color": {
					"background": "var:preset|color|ink",
					"text": "var:preset|color|paper"
				},
				"spacing": {
					"padding": {
						"bottom": "0.8rem",
						"left": "1.1rem",
						"right": "1.1rem",
						"top": "0.8rem"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "650"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|serif-display",
					"fontWeight": "500",
					"lineHeight": "1.04"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|evergreen"
				}
			}
		},
		"spacing": {
			"blockGap": "var:preset|spacing|40"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|system-sans",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.65"
		}
	}
}

